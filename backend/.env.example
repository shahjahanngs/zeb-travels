ALI_HAIDER_API_PASSWORD=your-external-api-password

# Optional: If you already have a valid JWT from Al-Haider,
# set it here to skip the login step entirely.
# When set, middleware will use this token for all requests.
# Example (do not commit real tokens):
# ALI_HAIDER_API_TOKEN=eyJ0eXAiOiJKV1QiLCJhbGciOiJSUzI1NiJ9....

# ===========================================
# HOW TO GET GMAIL APP PASSWORD:
# ===========================================
# 1. Go to https://myaccount.google.com/security
# 2. Enable 2-Step Verification (if not already enabled)
# 3. Go to https://myaccount.google.com/apppasswords
# 4. Select "Mail" and your device (or "Other")
# 5. Click "Generate"
# 6. Copy the 16-character password (remove spaces)
# 7. Paste it in EMAIL_PASSWORD above
#
# IMPORTANT: Use the App Password, NOT your regular Gmail password!
# IMPORTANT: Remove all spaces from the App Password
#
# Test your configuration by running:
#   node testCredentialEmail.js
# ===========================================
